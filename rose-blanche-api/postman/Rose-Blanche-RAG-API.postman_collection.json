{
  "info": {
    "_postman_id": "rose-blanche-rag-api-collection",
    "name": "Rose Blanche RAG API",
    "description": "Complete test collection for the Rose Blanche RAG API — a semantic search module for bakery & pastry formulation assistance.\n\nBase URL: http://localhost:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Info",
      "description": "Basic health-check and API information endpoints.",
      "item": [
        {
          "name": "Welcome / Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", ""]
            },
            "description": "Returns API metadata: app name, version, model info, and default top_k."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has app_name', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('app_name');",
                  "    pm.expect(body.app_name).to.include('Rose');",
                  "});",
                  "pm.test('Model is all-MiniLM-L6-v2', () => {",
                  "    pm.expect(pm.response.json().model).to.eql('all-MiniLM-L6-v2');",
                  "});",
                  "pm.test('Dimension is 384', () => {",
                  "    pm.expect(pm.response.json().dimension).to.eql(384);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

        {
          "name": "Search — Challenge Question (FR)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"question\": \"Quelles sont les quantités recommandées d'acide ascorbique, d'alpha-amylase et de xylanase pour l'amélioration de la panification ?\",\n    \"top_k\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/search/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "search", ""]
            },
            "description": "Main challenge question in French — asks for recommended quantities of ascorbic acid, alpha-amylase and xylanase for bread improvement."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Search success signal', () => {",
                  "    pm.expect(pm.response.json().signal).to.eql('search_success');",
                  "});",
                  "pm.test('Returns 3 results', () => {",
                  "    pm.expect(pm.response.json().results).to.have.lengthOf(3);",
                  "});",
                  "pm.test('Has metrics with scores', () => {",
                  "    const metrics = pm.response.json().metrics;",
                  "    pm.expect(metrics).to.have.property('average_score');",
                  "    pm.expect(metrics.average_score).to.be.above(0.5);",
                  "});",
                  "pm.test('Detected ingredients', () => {",
                  "    const metrics = pm.response.json().metrics;",
                  "    pm.expect(metrics).to.have.property('detected_ingredients');",
                  "    pm.expect(metrics.detected_ingredients.length).to.be.above(0);",
                  "});",
                  "pm.test('Ingredient coverage > 0', () => {",
                  "    const metrics = pm.response.json().metrics;",
                  "    pm.expect(metrics.ingredient_coverage).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
